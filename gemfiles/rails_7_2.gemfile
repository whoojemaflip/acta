# frozen_string_literal: true

source "https://rubygems.org"

gem "activejob",     "~> 7.2.0"
gem "activemodel",   "~> 7.2.0"
gem "activerecord",  "~> 7.2.0"
gem "activesupport", "~> 7.2.0"
gem "railties",      "~> 7.2.0"

group :development, :test do
  gem "irb"
  gem "pg", "~> 1.5"
  gem "rake", "~> 13.0"
  gem "rspec", "~> 3.13"
  gem "rubocop-rails-omakase", require: false
  gem "sqlite3", "~> 2.0"
end

gemspec path: ".."
